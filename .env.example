# Database
DATABASE_URL=postgres://user:password@localhost:5432/stackquadrant

# Auth
JWT_SECRET=change-me-to-a-random-64-char-hex-string
ADMIN_EMAIL=admin@stackquadrant.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# Email (Zoho EU SMTP)
SMTP_HOST=smtppro.zoho.eu
SMTP_PORT=465
SMTP_USER=info@stackquadrant.com
SMTP_PASS=your-zoho-app-password
FROM_EMAIL=info@stackquadrant.com

# GitHub API (for repo metrics sync)
GITHUB_TOKEN=ghp_your-github-personal-access-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
